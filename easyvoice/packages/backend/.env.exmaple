OPENAI_API_KEY=your_openai_key_here
MODEL_NAME=gpt-4o-mini
RATE_LIMIT_WINDOW=1
RATE_LIMIT=10
EDGE_API_LIMIT=10
DIRECT_GEN_LIMIT=200

